<SidePanel>:

    ScrollView:
        do_scroll_x: False

        UIShellPanelLayout:

            UIShellPanelSelectionLayout:
                id: widgets

    UIShellButton:
        text: "Settings"
        icon: "settings"
        pos_hint: {"x": 0.2, "y": 0.1}
        on_press:
            app.root.current = 'Settings'
