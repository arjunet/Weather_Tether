#:import FadeTransition kivy.uix.screenmanager.FadeTransition

<SidePanel>:
    size_hint_x: 0.5

    BoxLayout:
        orientation: 'vertical'
        size_hint: 1, 1

        ScrollView:
            do_scroll_x: False
            size_hint_y: None
            # Automatically take up all remaining space minus the bottom buttons
            height: self.parent.height - bottom_bar.height

            UIShellPanelLayout:
                UIShellPanelSelectionLayout:
                    id: widgets

        BoxLayout:
            id: bottom_bar
            orientation: 'vertical'
            size_hint_y: None
            height: dp(110) 
            padding: dp(30)
            spacing: dp(30)

            UIShellButton:
                text: "Refresh"
                icon: "restart"
                size_hint_y: None
                pos_hint: {"center_x": 0.5, "y": 0.2}
                halign: 'left'
                on_press:
                    app.root.current_screen.start_load_weather()
                    app.root.current_screen.ids.shell_menu_btn.active = not app.root.current_screen.ids.shell_menu_btn.active

            UIShellButton:
                text: "Settings"
                icon: "settings"
                size_hint_y: None
                pos_hint: {"center_x": 0.5, "y": 0.2}
                halign: 'left'
                on_press:
                    app.sm.current_screen.manager.transition = FadeTransition()
                    app.root.current = 'Settings'