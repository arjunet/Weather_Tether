#:import FadeTransition kivy.uix.screenmanager.FadeTransition

<SidePanel>:
    # Set the width of the panel
    size_hint_x: 0.5
    
    # We use a vertical BoxLayout to divide the panel into a scrollable area 
    # and a fixed bottom section.
    BoxLayout:
        orientation: 'vertical'
        size_hint: 1, 1

        # 1. The Scrollable Top Section
        ScrollView:
            do_scroll_x: False
            size_hint_y: None
            # Automatically take up all remaining space minus the bottom buttons
            height: self.parent.height - bottom_bar.height

            UIShellPanelLayout:
                UIShellPanelSelectionLayout:
                    id: widgets

        # 2. The Fixed Bottom Section
        BoxLayout:
            id: bottom_bar
            orientation: 'vertical'
            size_hint_y: None
            # Adjust height based on how many buttons you have (e.g., 2 buttons * 48dp height + spacing)
            height: dp(110) 
            padding: dp(10)
            spacing: dp(10)

            UIShellButton:
                text: "Refresh"
                icon: "restart"
                size_hint_y: None
                pos_hint: {"center_x": 0.5, "y": 0.2}
                halign: 'left'
                on_press:
                    app.root.current_screen.start_load_weather()
                    app.root.current_screen.ids.shell_menu_btn.active = not app.root.current_screen.ids.shell_menu_btn.active

            UIShellButton:
                text: "Settings"
                icon: "settings"
                size_hint_y: None
                pos_hint: {"center_x": 0.5, "y": 0.2}
                halign: 'left'
                on_press:
                    app.sm.current_screen.manager.transition = FadeTransition()
                    app.root.current = 'Settings'