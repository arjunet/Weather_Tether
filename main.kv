#:import FadeTransition kivy.uix.screenmanager.FadeTransition
#:import Window kivy.core.window.Window
#:import ClickableLabel helpers.clickablecomponents
#:import ClickableIcon helpers.clickablecomponents
# ---------------------------------------------------------------------------------
<SignupScreen>:
    CRelativeLayout:
        size_hint: 1, 1
        bg_color: app.blue_30

        # Signup Label:
        CLabel:
            text: "Signup"
            style: "heading_07"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.9}
            font_size: min(Window.width * 0.075, sp(32))

        # Email Text Input:
        CTextInputLayoutCircular:
            pos_hint: {"center_x": 0.5, "center_y": 0.75}
            size_hint_x: None
            width: min(Window.width * 0.83, dp(400))
            -bg_color: [1, 1, 1, 0.3]
            -hover_color: [1, 1, 1, 0.3]

            CTextInput:
                hint_text: "Email"
                -hint_text_color: "#2c2c2c"
                keyboard_suggestions: True
                id: email_input
                input_type: "mail"
                multiline: False
                on_text_validate: password_input.focus = True

            CTextInputHelperText:
                text: "Enter An Email That You Would Like to Use"
                -color: "#000000"

        # Password Text Input:
        CTextInputLayoutCircular:
            pos_hint: {"center_x": 0.5, "center_y": 0.55}
            size_hint_x: None
            width: min(Window.width * 0.83, dp(400))
            -bg_color: [1, 1, 1, 0.3]
            -hover_color: [1, 1, 1, 0.3]

            CTextInput:
                hint_text: "Password"
                -hint_text_color: "#2c2c2c"
                keyboard_suggestions: True
                password: True
                id: password_input
                multiline: False
                on_text_validate: 
                    self.focus: False

            CTextInputHelperText:
                text: "Enter A Password That You Would Like to Use"
                -color: "#000000"

            CTextInputTrailingIconButton:
                icon: "view--off" if password_input.password else "view"
                on_press:
                    password_input.password = (not password_input.password)

        # Privacy Policy agreement:
        CLabel:
            text: "I agree to the Privacy Policy listed in the below link:"
            pos_hint: {"center_x": 0.5, "center_y": 0.43}
            typeface: "IBM Plex Sans"
            halign: "center"
            color: (0,0,0,1)
            font_size: min(Window.width * 0.04, sp(16))
            weight_style: "Medium"
        
        CLink:
            url: "https://arjunet.github.io/Weather_Tether/privacy_policy.html"
            external: True
            pos_hint: {'center_x': 0.5, 'center_y': 0.37}
            id: Link

            CLinkText:
                text: "[b]Privacy Policy[/b]"
                font_size: sp(15)
                bg_color: app.transparent

            CLinkIcon:
                icon: "arrow--up-right"
                bg_color: app.transparent

        CCheckbox:
            line_width: dp(0.75)
            right: Link.x - dp(12)
            pos_hint: {'center_y': 0.37}
            id: checkbox
            width: min(Window.width * 0.07, dp(28))
            height: min(Window.width * 0.07, dp(28))
            on_active: root.check()

        # Login Button (users already have an account):
        ClickableLabel:
            text: "Already Have An Account? [u]Login[/u]"
            markup: True
            pos_hint: {'center_x': 0.5, 'center_y': 0.1}
            color: [0, 0, 0, 1]
            size_hint: None, None
            font_size: min(Window.width * 0.04, sp(16))
            weight_style: "Medium"
            on_press:
                root.manager.transition = FadeTransition()
                app.go_to_screen('Login')

        # Signup Button:
        CButtonCircular:
            text: "Signup"
            role: "Large Productive"
            pos_hint: {'center_x': 0.5, 'center_y': 0.25}
            icon: "login"
            bg_color: app.button_primary
            radius: [self.height/2]
            on_press:
                root.manager.transition = FadeTransition()
                root.start_load(root.ids.email_input.text, root.ids.password_input.text)

        CLoadingIndicator:
            role: "Large"
            opacity: 0
            id: loader
# ---------------------------------------------------------------------------------
<LoginScreen>:
    CRelativeLayout:
        size_hint: 1, 1
        bg_color: app.blue_30

        # Login Label:
        CLabel:
            text: "Login"
            style: "heading_07"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.9}
            font_size: min(Window.width * 0.075, sp(32))

        # Email Text Input:
        CTextInputLayoutCircular:
            pos_hint: {"center_x": 0.5, "center_y": 0.75}
            size_hint_x: None
            width: min(Window.width * 0.83, dp(400))
            -bg_color: [1, 1, 1, 0.3]
            -hover_color: [1, 1, 1, 0.3]

            CTextInput:
                hint_text: "Email"
                -hint_text_color: "#2c2c2c"
                keyboard_suggestions: True
                input_type: "mail"
                id: email_input
                multiline: False
                on_text_validate: password_input.focus = True

            CTextInputHelperText:
                text: "Enter Your Email"
                -color: "#000000"

        # Password Text Input:
        CTextInputLayoutCircular:
            pos_hint: {"center_x": 0.5, "center_y": 0.55}
            size_hint_x: None
            width: min(Window.width * 0.83, dp(400))
            -bg_color: [1, 1, 1, 0.3]
            -hover_color: [1, 1, 1, 0.3]

            CTextInput:
                hint_text: "Password"
                -hint_text_color: "#2c2c2c"
                password: True
                id: password_input
                multiline: False
                on_text_validate: 
                    self.focus: False

            CTextInputHelperText:
                text: "Enter Your Password"
                -color: "#000000"

            CTextInputTrailingIconButton:
                icon: "view--off" if password_input.password else "view"
                on_press:
                    password_input.password = (not password_input.password)

        # Privacy Policy agreement:
        CLabel:
            text: "I agree to the Privacy Policy listed in the below link:"
            pos_hint: {"center_x": 0.5, "center_y": 0.43}
            typeface: "IBM Plex Sans"
            halign: "center"
            color: (0,0,0,1)
            font_size: min(Window.width * 0.04, sp(16))
            weight_style: "Medium"
        
        CLink:
            url: "https://arjunet.github.io/Weather_Tether/privacy_policy.html"
            external: True
            pos_hint: {'center_x': 0.5, 'center_y': 0.37}
            id: Link

            CLinkText:
                text: "[b]Privacy Policy[/b]"
                font_size: sp(15)
                bg_color: app.transparent

            CLinkIcon:
                icon: "arrow--up-right"
                bg_color: app.transparent

        CCheckbox:
            line_width: dp(0.75)
            right: Link.x - dp(12)
            pos_hint: {'center_y': 0.37}
            id: checkbox
            width: min(Window.width * 0.07, dp(28))
            height: min(Window.width * 0.07, dp(28))
            on_active: root.check()

        # Back To Signup Button:
        ClickableLabel:
            text: "No Account Yet? [u]Signup[/u]"
            markup: True
            pos_hint: {'center_x': 0.5, 'center_y': 0.07}
            color: [0, 0, 0, 1]
            size_hint: None, None
            font_size: min(Window.width * 0.04, sp(16))
            weight_style: "Medium"
            on_press:
                root.manager.transition = FadeTransition()
                app.go_to_screen('Signup')

        # Forgot Password Button:
        ClickableLabel:
            text: "[u]Forgot Your Password?[/u]"
            markup: True
            pos_hint: {'center_x': 0.5, 'center_y': 0.19}
            color: [0, 0, 0, 1]
            size_hint: None, None
            font_size: min(Window.width * 0.04, sp(16))
            weight_style: "Medium"
            on_press:
                root.manager.transition = FadeTransition()
                app.go_to_screen('Forgot')

        # Login Button:
        CButtonCircular:
            text: "Login"
            role: "Large Productive"
            pos_hint: {'center_x': 0.5, 'center_y': 0.27}
            bg_color: app.button_primary
            radius: [self.height/2]
            icon: "login"
            on_press:
                root.manager.transition = FadeTransition()
                root.start_load(root.ids.email_input.text, root.ids.password_input.text)

        CLoadingIndicator:
            role: "Large"
            opacity: 0
            id: loader
# ---------------------------------------------------------------------------------
<ForgotScreen>:
    CRelativeLayout:
        size_hint: 1, 1
        bg_color: app.blue_30

        # Forgot Password Label:
        CLabel:
            text: "Forgot Your Password?"
            style: "heading_07"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.9}
            font_size: min(Window.width * 0.075, sp(32))

        # Email Text Input:
        CTextInputLayoutCircular:
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            size_hint_x: None
            width: min(Window.width * 0.83, dp(400))
            -bg_color: [1, 1, 1, 0.3]
            -hover_color: [1, 1, 1, 0.3]

            CTextInput:
                hint_text: "Email"
                -hint_text_color: "#2c2c2c"
                keyboard_suggestions: True
                id: email_input
                input_type: 'mail'
                multiline: False
                on_text_validate:
                    self.focus: False
                    root.start_load(root.ids.email_input.text.strip())
                    root.manager.transition = FadeTransition()
                    app.go_to_screen('Login')

            CTextInputHelperText:
                text: "Enter Your Email And We'll Send You A Code"
                -color: "#000000"

        # Back To Login Button:
        ClickableLabel:
            text: "[u]Back To Login[/u]"
            markup: True
            pos_hint: {'center_x': 0.5, 'center_y': 0.1}
            color: [0, 0, 0, 1]
            size_hint: None, None
            font_size: min(Window.width * 0.04, sp(16))
            weight_style: "Medium"
            on_press:
                root.manager.transition = FadeTransition()
                app.go_to_screen('Login')

        # Send Email Button:
        CButtonCircular:
            text: "Send Email"
            role: "Large Productive"
            pos_hint: {'center_x': 0.5, 'center_y': 0.33}
            icon: "send--alt"
            bg_color: app.button_primary
            radius: [self.height/2]
            on_press:
                root.start_load(root.ids.email_input.text.strip())
                root.manager.transition = FadeTransition()

        CLoadingIndicator:
            role: "Large"
            opacity: 0
            id: loader
# ---------------------------------------------------------------------------------
<SetupScreen>:
    CRelativeLayout:
        size_hint: 1, 1
        bg_color: app.blue_30

        # Setup Label:
        CLabel:
            text: "Setup"
            style: "heading_07"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.9}
            id: setup_label
            font_size: min(Window.width * 0.075, sp(32))

        # Address Text Input:
        CTextInputLayoutCircular:
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            size_hint_x: None
            width: min(Window.width * 0.83, dp(400))
            -bg_color: [1, 1, 1, 0.3]
            -hover_color: [1, 1, 1, 0.3]

            CTextInput:
                hint_text: "City or Zip Code"
                -hint_text_color: "#2c2c2c"
                keyboard_suggestions: True
                id: address_input
                input_type: "address"
                multiline: False
                on_text: root.start_lookup()
                on_text_validate: 
                    address_button.dispatch('on_press')
                    self.focus: False

            CTextInputHelperText:
                text: "Enter Your City or Zip Code"
                -color: "#000000"

        # Search Result Button:
        CButtonCircular:
            text: "Start typing"
            id: address_button
            role: "Large Productive"
            size_hint_x: 0.8          
            size_hint_y: None
            height: dp(180)
            pos_hint: {'y': 0}  
            text_size: self.width - dp(20), None
            disabled: True
            icon: "location--filled"
            -bg_color: app.button_primary
            -hover_color: app.button_primary
            radius: [self.height/2]
            pos_hint: {'center_x': 0.5}
            on_press:
                root.on_address_button_press(self.text.strip())

        AnchorLayout:
            anchor_x: "right"
            anchor_y: "top"
            padding: [dp(15), dp(18), dp(15), dp(15)]

            ClickableIcon:
                icon: "arrow--right"
                size_hint: None, None
                font_size: min(Window.width * 0.09, dp(34))
                on_press:
                    root.manager.transition = FadeTransition()
                    root.countinue_pressed()

        CLoadingIndicator:
            role: "Large"
            opacity: 0
            id: loader
# ---------------------------------------------------------------------------------
<VerifyScreen>:
    CRelativeLayout:
        size_hint: 1, 1
        bg_color: app.blue_30

        CLabel:
            text: "Check Your Inbox"
            style: "heading_07"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.9}
            font_size: min(Window.width * 0.075, sp(32))

        CLabel:
            text: "We Sent You An Email To Your Inbox. If You Can't Find It, Check Your Spam."
            style: "body_01"
            typeface: "IBM Plex Sans"
            weight_style: "Regular"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.7}
            font_size: min(Window.width * 0.04, sp(16))

        CButtonCircular:
            text: "Resend Verification Email"
            id: resend_button
            opacity: 0
            role: "Large Productive"
            icon: "send--alt"
            pos_hint: {'center_x': 0.5, 'center_y': 0.3}
            radius: [self.height/2]
            bg_color: [0, 0, 0, 1]
            size_hint: None, None
            width: max(Window.width * 0.11, dp(270))
            font_size: min(Window.width * 0.05, sp(17))
            on_press:
                root.start_load_send()

        AnchorLayout:
            anchor_x: "right"
            anchor_y: "top"
            padding: [dp(15), dp(15), dp(15), dp(15)]
            
            # Continue icon:
            ClickableIcon:
                icon: "arrow--right"
                size_hint: None, None
                font_size: min(Window.width * 0.09, dp(34))
                on_press:
                    root.start_load_check()

        ClickableLabel:
            text: "Wrong Email?"
            markup: True
            pos_hint: {'center_x': 0.5, 'center_y': 0.1}
            color: [0, 0, 0, 1]
            size_hint: None, None
            font_size: min(Window.width * 0.04, sp(16))
            weight_style: "Medium"
            on_press:
                root.open_logout_modal()

        CLoadingIndicator:
            role: "Large"
            opacity: 0
            id: loader
# ---------------------------------------------------------------------------------
<BaseScreen>:
    CBoxLayout:
        orientation: 'vertical'
        size_hint: 1, 1
        bg_source: root.bg_image

        # Header with location and menu
        CBoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(60)
            padding: [dp(15), dp(10), dp(15), dp(10)]
            spacing: dp(10)
            bg_color: (1, 1, 1, 0.1)

        # Scrollable content
        CScrollView:
            size_hint: 1, 1
            do_scroll_x: False

            CBoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: [dp(15), dp(15), dp(15), dp(15)]
                spacing: dp(15)

                CLabel:
                    id: city_label
                    style: "heading_02"
                    typeface: "IBM Plex Sans"
                    weight_style: "Medium"
                    halign: "center"
                    valign: "middle"
                    text_size: self.size
                    color: (0,0,0,1)
                    pos_hint: {'center_x': 0.5}
                    font_size: min(Window.width * 0.045, dp(27))
                    size_hint_y: None
                    height: dp(40)

                # Main weather card
                CBoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: dp(150)
                    spacing: dp(20)
                    padding: [dp(20), dp(20), dp(20), dp(20)]
                    canvas.before:
                        Color:
                            rgba: root.transparency_color
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(20)]

                    CBoxLayout:
                        size_hint: None, 1
                        width: dp(100)
                        
                        AsyncImage:
                            id: weather_icon
                            source: root.icon_path
                            size_hint: 1, 1
                            opacity: 0

                    CBoxLayout:
                        orientation: 'vertical'
                        size_hint_x: 1
                        padding: [dp(10), 0, dp(10), 0]
                        spacing: dp(5)

                        CLabel:
                            id: current_temp_label
                            text: "--°F"
                            style: "heading_02"
                            typeface: "IBM Plex Sans"
                            weight_style: "Medium"
                            halign: "left"
                            color: (0, 0, 0, 1)
                            font_size: min(Window.width * 0.08, sp(48))
                            size_hint_y: None
                            height: dp(60)

                # 2x2 Grid for weather details
                CGridLayout:
                    cols: 2
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(15)

                    # Condition card
                    CBoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: dp(100)
                        padding: [dp(15), dp(15), dp(15), dp(15)]
                        spacing: dp(5)
                        canvas.before:
                            Color:
                                rgba: root.transparency_color
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(15)]

                        CLabel:
                            text: "Condition"
                            style: "body_01"
                            typeface: "IBM Plex Sans"
                            weight_style: "Regular"
                            color: (0, 0, 0, 1)
                            font_size: min(Window.width * 0.035, sp(14))
                            size_hint_y: None
                            height: dp(20)

                        CLabel:
                            id: condition_label
                            text: "?"
                            style: "heading_05"
                            typeface: "IBM Plex Sans"
                            weight_style: "Medium"
                            color: (0, 0, 0, 1)
                            font_size: min(Window.width * 0.045, sp(20))
                            size_hint_y: None
                            height: dp(50)

                    # High/Low card
                    CBoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: dp(100)
                        padding: [dp(15), dp(15), dp(15), dp(15)]
                        spacing: dp(5)
                        canvas.before:
                            Color:
                                rgba: root.transparency_color
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(15)]

                        CLabel:
                            text: "High / Low"
                            style: "body_01"
                            typeface: "IBM Plex Sans"
                            weight_style: "Regular"
                            color: (0, 0, 0, 1)
                            font_size: min(Window.width * 0.035, sp(14))
                            size_hint_y: None
                            height: dp(20)

                        CLabel:
                            id: min_max_label
                            text: "--° / --°"
                            style: "heading_05"
                            typeface: "IBM Plex Sans"
                            weight_style: "Medium"
                            color: (0, 0, 0, 1)
                            font_size: min(Window.width * 0.045, sp(20))
                            size_hint_y: None
                            height: dp(50)

                    # Feels Like card
                    CBoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: dp(100)
                        padding: [dp(15), dp(15), dp(15), dp(15)]
                        spacing: dp(5)
                        canvas.before:
                            Color:
                                rgba: root.transparency_color
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(15)]

                        CLabel:
                            text: "Feels Like"
                            style: "body_01"
                            typeface: "IBM Plex Sans"
                            weight_style: "Regular"
                            color: (0, 0, 0, 1)
                            font_size: min(Window.width * 0.035, sp(14))
                            size_hint_y: None
                            height: dp(20)

                        CLabel:
                            id: feels_like_label
                            text: "--°F"
                            style: "heading_05"
                            typeface: "IBM Plex Sans"
                            weight_style: "Medium"
                            color: (0, 0, 0, 1)
                            font_size: min(Window.width * 0.045, sp(20))
                            size_hint_y: None
                            height: dp(50)

                    # Wind Chill card
                    CBoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: dp(100)
                        padding: [dp(15), dp(15), dp(15), dp(15)]
                        spacing: dp(5)
                        canvas.before:
                            Color:
                                rgba: root.transparency_color
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(15)]

                        CLabel:
                            text: "Wind Chill"
                            style: "body_01"
                            typeface: "IBM Plex Sans"
                            weight_style: "Regular"
                            color: (0, 0, 0, 1)
                            font_size: min(Window.width * 0.035, sp(14))
                            size_hint_y: None
                            height: dp(20)

                        CLabel:
                            id: wind_chill_label
                            text: "--°F"
                            style: "heading_05"
                            typeface: "IBM Plex Sans"
                            weight_style: "Medium"
                            color: (0, 0, 0, 1)
                            font_size: min(Window.width * 0.045, sp(20))
                            size_hint_y: None
                            height: dp(50)

                # Precipitation card
                CBoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(80)
                    padding: [dp(15), dp(15), dp(15), dp(15)]
                    spacing: dp(5)
                    canvas.before:
                        Color:
                            rgba: root.transparency_color
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(15)]

                    CLabel:
                        text: "Precipitation"
                        style: "body_01"
                        typeface: "IBM Plex Sans"
                        weight_style: "Regular"
                        color: (0, 0, 0, 1)
                        font_size: min(Window.width * 0.035, sp(14))
                        size_hint_y: None
                        height: dp(20)

                    CLabel:
                        id: precip_label
                        text: "--%"
                        style: "heading_05"
                        typeface: "IBM Plex Sans"
                        weight_style: "Medium"
                        color: (0, 0, 0, 1)
                        font_size: min(Window.width * 0.045, sp(20))
                        size_hint_y: None
                        height: dp(40)

                # Snow card
                CBoxLayout:
                    opacity: 0 if snow_label.text in ["0 Inches Of Snow", "0 Centimeters Of Snow"] else 1
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(80)
                    padding: [dp(15), dp(15), dp(15), dp(15)]
                    spacing: dp(5)
                    canvas.before:
                        Color:
                            rgba: root.transparency_color
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(15)]

                    CLabel:
                        text: "Snow"
                        style: "body_01"
                        typeface: "IBM Plex Sans"
                        weight_style: "Regular"
                        color: (0, 0, 0, 1)
                        font_size: min(Window.width * 0.035, sp(14))
                        size_hint_y: None
                        height: dp(20)

                    CLabel:
                        id: snow_label
                        text: "- in"
                        style: "heading_05"
                        typeface: "IBM Plex Sans"
                        weight_style: "Medium"
                        color: (0, 0, 0, 1)
                        font_size: min(Window.width * 0.045, sp(20))
                        size_hint_y: None
                        height: dp(40)

    FloatLayout:
        size_hint: 1, 1
        pos_hint: {'x': 0, 'y': 0}

        CLoadingIndicator:
            id: loader
            role: "Large"
            opacity: 0
            size_hint: None, None
            size: dp(50), dp(50)
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}

    UIShell:
        id: left_panel_shell

        SidePanel:
            id: SidePanel
            panel_shell: left_panel_shell
            visibility: shell_menu_btn.active

            scroll_layout: scrollview_layout

            UIShellPanelLayout:
                CBoxLayout:
                    orientation: 'vertical'
                    spacing: dp(10)
                    padding: dp(10)

                    CScrollView:
                        size_hint_y: 1
                        bar_width: dp(8.5)
                        scroll_type: ['bars', 'content']
                        
                        CBoxLayout:
                            id: scrollview_layout
                            orientation: 'vertical'
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: dp(5)

                    # Empty blank zones for bottom sidepanel buttons
                    CBoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: dp(150)
                        spacing: dp(20)

    UIShell:
        id: header_shell

        UIShellHeader:
            id: shell_header
            -bg_color: app.transparent

            UIShellHeaderMenuButton:
                id: shell_menu_btn
                on_press: root.add_buttons()

            CAnchorLayout:
                anchor_x: "right"

                CGridLayout:
                    adaptive: [True, True]
                    rows: 1
                    spacing: dp(10)
                    id: container
# ---------------------------------------------------------------------------------
<SettingsScreen>:
    CRelativeLayout:
        size_hint: 1, 1
        bg_color: app.blue_30
        spacing: dp(80)

        # Settings Label:
        CLabel:
            text: "Settings"
            style: "heading_07"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.9}
            font_size: min(Window.width * 0.075, sp(32))

        CButtonCircular:
            role: "Large Productive"
            icon: "add"
            text: "Add City"
            pos_hint: {'center_x': 0.5, 'center_y': 0.43}
            bg_color: [0, 0, 0, 1]
            radius: [self.height/2]
            on_press:
                root.manager.transition = FadeTransition()
                root.open_add_city_modal()

        CButtonDanger:
            text: "Logout"
            role: "Large Productive"
            icon: "logout"
            pos_hint: {'center_x': 0.5, 'center_y': 0.3}
            on_press:
                root.open_logout_modal()

        CButtonDanger:
            text: "Delete Account"
            role: "Large Productive"
            icon: "trash-can"
            pos_hint: {'center_x': 0.5, 'center_y': 0.2}
            on_press:
                root.open_delete_modal()

        AnchorLayout:
            anchor_x: "left"
            anchor_y: "top"
            padding: [dp(15), dp(18), dp(15), dp(15)]

            ClickableIcon:
                icon: "arrow--left"
                size_hint: None, None
                font_size: min(Window.width * 0.09, dp(34))
                on_press:
                    root.manager.transition = FadeTransition()
                    app.set_previous_screen()

        CToggle:
            id: unit_toggle
            pos_hint: {"center_x": 0.5, "center_y": 0.6}
            on_active:
                root.toggle_pressed()

        CLabel:
            text: "Imperial Units"
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Regular"
            halign: "center"
            size_hint: None, None
            size: self.texture_size
            color: (0,0,0,1)
            size_hint: 1, 1
            center_x: unit_toggle.center_x - dp(80)
            center_y: unit_toggle.center_y
            font_size: sp(16)

        CLabel:
            text: "Metric Units"
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Regular"
            halign: "center"
            size_hint: None, None
            size: self.texture_size
            color: (0,0,0,1)
            size_hint: 1, 1
            center_x: unit_toggle.center_x + dp(80)
            center_y: unit_toggle.center_y
            font_size: sp(16)

        CLink:
            url: "https://arjunet.github.io/Weather_Tether/privacy_policy.html"
            external: True
            pos_hint: {'center_x': 0.5, 'center_y': 0.1}

            CLinkText:
                text: "[b]Privacy Policy[/b]"
                font_size: sp(25)

            CLinkIcon:
                icon: "arrow--up-right"

        CLoadingIndicator:
            role: "Large"
            opacity: 0
            id: loader
# ---------------------------------------------------------------------------------
<LogoutModal>:
    CModalLayout:
        CModalHeader:
            CModalHeaderLabel:
                text: "Logout"

            CModalHeaderTitle:
                text: "Are you sure you want to logout?"

        CModalBody:
            CModalBodyContent:
                text: "Logging out will require you to login again with your email and password. Your saved location and unit preference will not be saved."

        CModalFooter:
            CGridLayout:
                cols: 2
                adaptive: [False, True]
                spacing: dp(1)

                CButtonSecondary:
                    text: "Cancel"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.dismiss()

                CButtonDanger:
                    text: "Logout"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.logout_confirmed()

    CModalCloseButton:
        on_press:
            root.dismiss()
# ---------------------------------------------------------------------------------
<LogoutVerifyModal>:
    CModalLayout:
        CModalHeader:
            CModalHeaderLabel:
                text: "Wrong Email?"

            CModalHeaderTitle:
                text: "Are you sure you You Have Signed Up With The Wrong Email?"

        CModalBody:
            CModalBodyContent:
                text: "The Wrong Email Will Be Automatically Removed And You May Signup With The Correct Email"

        CModalFooter:
            CGridLayout:
                cols: 2
                adaptive: [False, True]
                spacing: dp(1)

                CButtonSecondary:
                    text: "Cancel"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.dismiss()

                CButtonDanger:
                    text: "Change Email"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.logout_confirmed()

    CModalCloseButton:
        on_press:
            root.dismiss()
# ---------------------------------------------------------------------------------
<DeleteModal>:
    CModalLayout:
        CModalHeader:
            CModalHeaderLabel:
                text: "Delete Account"

            CModalHeaderTitle:
                text: "Are you sure you want to delete your account?"

        CModalBody:
            CModalBodyContent:
                text: "Deleting your account will permanently delete all of your data from our servers, including your saved location and unit preference. This action cannot be undone."

            CBoxLayout:
                adaptive: [False, True]
                spacing: dp(32)
                padding: dp(16)
                orientation: "vertical"

                # Email Text Input:
                CTextInputLayoutCircular:
                    pos_hint: {"center_x": 0.5}
                    -bg_color: [1, 1, 1, 0.3]
                    -hover_color: [1, 1, 1, 0.3]

                    CTextInput:
                        hint_text: "Email"
                        id: email_input
                        hint_text_color: "#2c2c2c"
                        keyboard_suggestions: True
                        input_type: "mail"
                        multiline: False
                        on_text_validate: password_input.focus = True

                    CTextInputHelperText:
                        text: "Enter Your Email"
                        color: "#000000"

                # Password Text Input:
                CTextInputLayoutCircular:
                    pos_hint: {"center_x": 0.5}
                    -bg_color: [1, 1, 1, 0.3]
                    -hover_color: [1, 1, 1, 0.3]

                    CTextInput:
                        hint_text: "Password"
                        hint_text_color: "#2c2c2c"
                        password: True
                        id: password_input
                        multiline: False
                        on_text_validate: self.focus = False

                    CTextInputHelperText:
                        text: "Enter Your Password"
                        color: "#000000"

                    CTextInputTrailingIconButton:
                        icon: "view--off" if password_input.password else "view"
                        on_press:
                            password_input.password = (not password_input.password)

        CModalFooter:
            CGridLayout:
                cols: 2
                adaptive: [False, True]
                spacing: dp(1)

                CButtonSecondary:
                    text: "Cancel"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.dismiss()

                CButtonDanger:
                    text: "Delete"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.delete_confirmed(root.ids.email_input.text, root.ids.password_input.text)

    CModalCloseButton:
        on_press:
            root.dismiss()
# ----------------------------------------------------------------------------------
<AddCityModal>:
    auto_dismiss: False
    CModalLayout:
        CModalHeader:
            CModalHeaderLabel:
                text: "Add City"

            CModalHeaderTitle:
                id: header_title

        CModalBody:
            CModalBodyContent:
                id: body

            CBoxLayout:
                adaptive: [False, True]
                padding: [0, dp(64)]

                CTextInputLayoutCircular:
                    size_hint_x: 0.65
                    -bg_color: [1, 1, 1, 0.3]
                    -hover_color: [1, 1, 1, 0.3]

                    CTextInput:
                        hint_text: "e.g. New York"
                        id: address_input
                        hint_text_color: "#2c2c2c"
                        keyboard_suggestions: True
                        input_type: "address"
                        multiline: False
                        on_text: root.start_lookup()
                        on_text_validate: 
                            address_button.dispatch('on_press')
                            self.focus: False

                    CTextInputLabel:
                        text: "City Name"

                    CLoadingIndicator:
                        id: loader
                        role: "Small"
                        opacity: 0

            CButtonCircular:
                text: "Start typing"
                id: address_button
                role: "Large Productive"
                size_hint_x: 1          
                size_hint_y: None
                height: dp(100) 
                length: 1
                text_size: self.width - dp(20), None
                disabled: True
                -bg_color: app.button_primary
                -hover_color: app.button_primary
                radius: [self.height/2]
                icon: "location--filled"
                on_press:
                    root.on_address_button_press(self.text.strip())

        CModalFooter:
            CGridLayout:
                cols: 2
                adaptive: [False, True]
                spacing: dp(1)

                CButtonSecondary:
                    text: "Cancel"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.dismiss()
                        app.sm.current = "Settings"

                CButtonPrimary:
                    text: "Add"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.countinue_pressed()

    CModalCloseButton:
        on_press:
            root.dismiss()
            app.sm.current = "Settings"
# ---------------------------------------------------------------------------------
<ChangeLocationModal>:
    auto_dismiss: False
    CModalLayout:
        CModalHeader:
            CModalHeaderLabel:
                text: "Change Location"

            CModalHeaderTitle:
                text: "Would You Like To Change Your Location?"

        CModalBody:
            CModalBodyContent:
                text: "Changing your location will update your weather information to reflect the new city."

            CBoxLayout:
                adaptive: [False, True]
                padding: [0, dp(64)]

                CTextInputLayoutCircular:
                    size_hint_x: 0.65
                    -bg_color: [1, 1, 1, 0.3]
                    -hover_color: [1, 1, 1, 0.3]

                    CTextInput:
                        hint_text: "e.g. New York"
                        id: address_input
                        hint_text_color: "#2c2c2c"
                        keyboard_suggestions: True
                        input_type: "mail"
                        multiline: False
                        on_text: root.start_lookup()
                        on_text_validate: 
                            address_button.dispatch('on_press')
                            self.focus: False

                    CTextInputLabel:
                        text: "City Name"

                    CLoadingIndicator:
                        id: loader
                        role: "Small"
                        opacity: 0

            CButtonCircular:
                text: "Start typing"
                id: address_button
                role: "Large Productive"
                size_hint_x: 1          
                size_hint_y: None
                height: dp(100) 
                length: 1
                text_size: self.width - dp(20), None
                disabled: True
                icon: "location--filled"
                -bg_color: app.button_primary
                -hover_color: app.button_primary
                radius: [self.height/2]
                on_press:
                    root.on_address_button_press(self.text.strip())

        CModalFooter:
            CGridLayout:
                cols: 2
                adaptive: [False, True]
                spacing: dp(1)

                CButtonSecondary:
                    text: "Cancel"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.dismiss()

                CButtonPrimary:
                    text: "Change"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.countinue_pressed()

    CModalCloseButton:
        on_press:
            root.dismiss()
# ---------------------------------------------------------------------------------
<DeleteLocationModal>:
    CModalLayout:
        CModalHeader:
            CModalHeaderLabel:
                text: "Delete Location"

            CModalHeaderTitle:
                text: "Are you sure you want to delete this location?"

        CModalBody:
            CModalBodyContent:
                text: "Deleting this location will permanently remove it from your account. This action cannot be undone."

        CModalFooter:
            CGridLayout:
                cols: 2
                adaptive: [False, True]
                spacing: dp(1)

                CButtonSecondary:
                    text: "Cancel"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.dismiss()

                CButtonDanger:
                    text: "Delete"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.delete_confirmed()

    CModalCloseButton:
        on_press:
            root.dismiss()
