            -bg_color: app.transparent

            UIShellHeaderMenuButton:
                id: shell_menu_btn
                on_press: root.add_buttons()

            CAnchorLayout:
                anchor_x: "right"

                CGridLayout:
                    adaptive: [True, True]
                    rows: 1
