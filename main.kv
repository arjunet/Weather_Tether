                    UIShellButton:
                        role: "Large Productive"
                        icon: "trash-can"
                        bg_color: "#0f62fe"
                        opacity: 0 if not shell_menu_btn.active else 1
                        on_press:
                            root.open_delete_location_modal()

# ----------------------------------------------------------------------------------

<AddCityModal>:
    CModalLayout:
        CModalHeader:
            CModalHeaderLabel:
                text: "Add City"
            CModalHeaderTitle:
                id: header_title
        CModalBody:
            CModalBodyContent:
                id: body
            CBoxLayout:
                adaptive: [False, True]
                padding: [0, dp(64)]

                CTextInputLayout:
                    CTextInput:
                        hint_text: "e.g. New York"
                        id: address_input
                        input_type: "address"
                        on_text: 
                            root.start_lookup()

                    CTextInputLabel:
                        text: "City Name"

                    CLoadingIndicator:
                        id: loader
                        role: "Small"
                        opacity: 0

            CButtonPrimary:
                text: "Start typing"
                id: address_button
                role: "Large Productive"
                size_hint_x: 1          
                size_hint_y: None
                height: dp(100) 
                length: 1
                text_size: self.width - dp(20), None
                disabled: True
                icon: "location--filled"
                on_press:
                    root.on_address_button_press(self.text.strip())


        CModalFooter:
            CGridLayout:
                cols: 2
                adaptive: [False, True]
                spacing: dp(1)

                CButtonSecondary:
                    text: "Cancel"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.dismiss()
                        app.root.current = 'App'

                CButtonPrimary:
                    text: "Add"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.countinue_pressed()

    CModalCloseButton:
        on_press:
            root.dismiss()
            app.root.current = 'App'
# ---------------------------------------------------------------------------------


<City3Screen>:
    CRelativeLayout:

        AsyncImage:
            source: root.bg_image
            size_hint: 1, 1
            fit_mode: "cover"

        AsyncImage:
            id: weather_icon
            source: root.icon_path 
            size_hint: (None, None)
            size: ("100dp", "100dp")
            pos_hint: {'center_x': 0.25, 'center_y': 0.75}

        CLabel:
            id: city_label
            style: "heading_02"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.95}
            font_size: sp(20)

        CLabel:
            id: current_temp_label
            style: "heading_02"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            center_x: weather_icon.center_x + dp(100)
            center_y: weather_icon.center_y - dp(8.5)
            font_size: sp(20)

        CLabel:
            id: condition_label
            style: "heading_04" 
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            center_x: weather_icon.center_x + dp(5)
            center_y: weather_icon.center_y - dp(60)
            font_size: sp(10)

        CLabel:
            id: min_max_label
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            center_x: weather_icon.center_x + dp(5)
            center_y: weather_icon.center_y - dp(90)
            font_size: sp(10)

        CLabel:
            id: wind_chill_label
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            center_x: weather_icon.center_x + dp(5)
            center_y: weather_icon.center_y - dp(120)
            font_size: sp(10)

        CLabel:
            id: precip_label
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.4}
            font_size: sp(15)

        CLabel:
            id: snow_label
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.3}
            font_size: sp(15)

        CLabel:
            id: thunder_label
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.2}
            font_size: sp(15)

        CLoadingIndicator:
            role: "Large"
            opacity: 0
            id: loader

    UIShell:
        id: left_panel_shell

        SidePanel:
            id: SidePanel
            panel_shell: left_panel_shell
            visibility: shell_menu_btn.active

    UIShell:
        id: header_shell

        UIShellHeader:
            id: shell_header
            -bg_color: app.transparent

            UIShellHeaderMenuButton:
                id: shell_menu_btn

            CAnchorLayout:
                anchor_x: "right"

                CGridLayout:
                    adaptive: [True, True]
                    rows: 1

                    UIShellButton:
                        role: "Large Productive"
                        icon: "edit"
                        bg_color: "#0f62fe"
                        opacity: 0 if not shell_menu_btn.active else 1
                        on_press:
                            root.open_change_location_modal()

                    UIShellButton:
                        role: "Large Productive"
                        icon: "trash-can"
                        bg_color: "#0f62fe"
                        opacity: 0 if not shell_menu_btn.active else 1
                        on_press:
                            root.open_delete_location_modal()
# ---------------------------------------------------------------------------------

<ChangeLocationModal>:
    CModalLayout:
        CModalHeader:
            CModalHeaderLabel:
                text: "Change Location"
            CModalHeaderTitle:
                text: "Would You Like To Change Your Location?"
        CModalBody:
            CModalBodyContent:
                text: "Changing your location will update your weather information to reflect the new city."
            CBoxLayout:
                adaptive: [False, True]
                padding: [0, dp(64)]

                CTextInputLayout:
                    CTextInput:
                        hint_text: "e.g. New York"
                        id: address_input
                        on_text: 
                            root.start_lookup()
                    CTextInputLabel:
                        text: "City Name"

                    CLoadingIndicator:
                        id: loader
                        role: "Small"
                        opacity: 0

            CButtonPrimary:
                text: "Start typing"
                id: address_button
                role: "Large Productive"
                size_hint_x: 1          
                size_hint_y: None
                height: dp(100) 
                length: 1
                text_size: self.width - dp(20), None
                disabled: True
                icon: "location--filled"
                on_press:
                    root.on_address_button_press(self.text.strip())


        CModalFooter:
            CGridLayout:
                cols: 2
                adaptive: [False, True]
                spacing: dp(1)

                CButtonSecondary:
                    text: "Cancel"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.dismiss()

                CButtonPrimary:
                    text: "Add"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.countinue_pressed()

    CModalCloseButton:
        on_press:
            root.dismiss()
            app.root.current = 'App'
# ---------------------------------------------------------------------------------
<DeleteLocationModal>:
    CModalLayout:
        CModalHeader:
            CModalHeaderLabel:
                text: "Delete Location"
            CModalHeaderTitle:
                text: "Are you sure you want to delete this location?"
        CModalBody:
            CModalBodyContent:
                text: "Deleting this location will permanently remove it from your account. This action cannot be undone."
        CModalFooter:
            CGridLayout:
                cols: 2
                adaptive: [False, True]
                spacing: dp(1)

                CButtonSecondary:
                    text: "Cancel"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.dismiss()
                        app.root.current = 'App'

                CButtonDanger:
                    text: "Delete"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.delete_confirmed()

    CModalCloseButton:
        on_press:
            root.dismiss()
            app.root.current = 'App'