            center_x: weather_icon.center_x + dp(100)
            center_y: weather_icon.center_y + dp(15)
            font_size: min(Window.width * 0.06, sp(27))

        CLabel:
            id: condition_label
            style: "heading_04" 
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            center_x: weather_icon.center_x + dp(5)
            center_y: weather_icon.center_y - dp(60)
            font_size: min(Window.width * 0.03, sp(12))

        CLabel:
            id: min_max_label
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            center_x: weather_icon.center_x + dp(5)
            center_y: weather_icon.center_y - dp(90)
            font_size: min(Window.width * 0.03, sp(12))

        CLabel:
            id: wind_chill_label
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            center_x: weather_icon.center_x + dp(5)
            center_y: weather_icon.center_y - dp(120)
            font_size: min(Window.width * 0.03, sp(12))

        CLabel:
            id: precip_label
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5}
            center_y: weather_icon.center_y - dp(250)
            font_size: min(Window.width * 0.05, sp(12))

        CLabel:
            id: snow_label
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5}
            center_y: weather_icon.center_y - dp(300)
            font_size: min(Window.width * 0.05, sp(12))

        CLoadingIndicator:
            role: "Large"
            opacity: 0
            id: loader

    UIShell:
        id: left_panel_shell

        SidePanel:
            id: SidePanel
            panel_shell: left_panel_shell
            visibility: shell_menu_btn.active

    UIShell:
        id: header_shell

        UIShellHeader:
            id: shell_header
            -bg_color: app.transparent

            UIShellHeaderMenuButton:
                id: shell_menu_btn
                on_press: root.add_buttons()

            CAnchorLayout:
                anchor_x: "right"

                CGridLayout:
                    adaptive: [True, True]
                    rows: 1
                    spacing: dp(10)
                    id: container
# ---------------------------------------------------------------------------------
<SettingsScreen>:
    CRelativeLayout:
        size_hint: 1, 1
        bg_source: "images/sun_bg.jpg"
        spacing: dp(80)

        # Settings Label:
        CLabel:
            text: "Settings"
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.9}
            font_size: min(Window.width * 0.075, sp(32))

        CButtonCircular:
            role: "Large Productive"
            icon: "building"
            text: "Add City"
            pos_hint: {'center_x': 0.5, 'center_y': 0.43}
            bg_color: [0, 0, 0, 1]
            radius: [self.height/2]
            on_press:
                root.manager.transition = FadeTransition()
                root.open_add_city_modal()

        CButtonDanger:
            text: "Logout"
            role: "Large Productive"
            icon: "logout"
            pos_hint: {'center_x': 0.5, 'center_y': 0.3}
            on_press:
                root.open_logout_modal()

        CButtonDanger:
            text: "Delete Account"
            role: "Large Productive"
            icon: "trash-can"
            pos_hint: {'center_x': 0.5, 'center_y': 0.2}
            on_press:
                root.open_delete_modal()

        AnchorLayout:
            anchor_x: "left"
            anchor_y: "top"
            padding: [dp(15), dp(15), dp(15), dp(15)]

            CButtonCircular:
                icon: "right-panel--open--filled"
                text: "Back"
                pos_hint: {'right': 0.35, 'top': 0.93}
                bg_color: [0, 0, 0, 1]
                radius: [self.height/2]
                on_press:
                    root.manager.transition = FadeTransition()
                    root.manager.current = 'App'

        CToggle:
            id: unit_toggle
            pos_hint: {"center_x": 0.5, "center_y": 0.6}
            on_active:
                root.toggle_pressed()

        CLabel:
            text: "Imperial Units"
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Regular"
            halign: "center"
            color: (0,0,0,1)
            size_hint: 1, 1
            center_x: unit_toggle.center_x - dp(80)
            center_y: unit_toggle.center_y
            font_size: sp(16)

        CLabel:
            text: "Metric Units"
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Regular"
            halign: "center"
            color: (0,0,0,1)
            size_hint: 1, 1
            center_x: unit_toggle.center_x + dp(80)
            center_y: unit_toggle.center_y
            font_size: sp(16)

        CLink:
            url: "https://arjunet.github.io/Weather_Tether/privacy_policy.html"
            external: True
            pos_hint: {'center_x': 0.5, 'center_y': 0.1}

            CLinkText:
                text: "[b]Privacy Policy[/b]"
                font_size: sp(25)
                bg_color: "white"

            CLinkIcon:
                icon: "arrow--up-right"
                bg_color: "white"

        CLoadingIndicator:
            role: "Large"
            opacity: 0
            id: loader
# ---------------------------------------------------------------------------------
<LogoutModal>:
    CModalLayout:
        CModalHeader:
            CModalHeaderLabel:
                text: "Logout"

            CModalHeaderTitle:
                text: "Are you sure you want to logout?"

        CModalBody:
            CModalBodyContent:
                text: "Logging out will require you to login again with your email and password. Your saved location and unit preference will not be saved."

        CModalFooter:
            CGridLayout:
                cols: 2
                adaptive: [False, True]
                spacing: dp(1)

                CButtonSecondary:
                    text: "Cancel"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.dismiss()

                CButtonDanger:
                    text: "Logout"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.logout_confirmed()

    CModalCloseButton:
        on_press:
            root.dismiss()
# ---------------------------------------------------------------------------------
<DeleteModal>:
    CModalLayout:
        CModalHeader:
            CModalHeaderLabel:
                text: "Delete Account"

            CModalHeaderTitle:
                text: "Are you sure you want to delete your account?"

        CModalBody:
            CModalBodyContent:
                text: "Deleting your account will permanently delete all of your data from our servers, including your saved location and unit preference. This action cannot be undone."

            CBoxLayout:
                adaptive: [False, True]
                spacing: dp(32)
                padding: dp(16)
                orientation: "vertical"

                # Email Text Input:
                CTextInputLayout:
                    pos_hint: {"center_x": 0.5}

                    CTextInput:
                        hint_text: "Email"
                        id: email_input
                        input_type: "mail"
                        bg_color: [1, 1, 1, 1]

                    CTextInputHelperText:
                        text: "Enter Your Email"
                        color: "#000000"

                # Password Text Input:
                CTextInputLayout:
                    pos_hint: {"center_x": 0.5}

                    CTextInput:
                        hint_text: "Password"
                        password: True
                        id: password_input
                        bg_color: [1, 1, 1, 1]

                    CTextInputHelperText:
                        text: "Enter Your Password"
                        color: "#000000"

                    CTextInputTrailingIconButton:
                        icon: "view--off" if password_input.password else "view"
                        on_press:
                            password_input.password = (not password_input.password)

        CModalFooter:
            CGridLayout:
                cols: 2
                adaptive: [False, True]
                spacing: dp(1)

                CButtonSecondary:
                    text: "Cancel"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.dismiss()

                CButtonDanger:
                    text: "Delete"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.delete_confirmed(root.ids.email_input.text, root.ids.password_input.text)

    CModalCloseButton:
        on_press:
            root.dismiss()
# ----------------------------------------------------------------------------------
<AddCityModal>:
    auto_dismiss: False

    CModalLayout:
        CModalHeader:
            CModalHeaderLabel:
                text: "Add City"

            CModalHeaderTitle:
                id: header_title

        CModalBody:
            CModalBodyContent:
                id: body

            CBoxLayout:
                adaptive: [False, True]
                padding: [0, dp(64)]

                CTextInputLayout:
                    size_hint_x: 0.65
                    CTextInput:
                        hint_text: "e.g. New York"
                        id: address_input
                        input_type: "address"
                        bg_color: [1, 1, 1, 1]
                        on_text: 
                            root.start_lookup()

                    CTextInputLabel:
                        text: "City Name"

                    CLoadingIndicator:
                        id: loader
                        role: "Small"
                        opacity: 0

            CButtonPrimary:
                text: "Start typing"
                id: address_button
                role: "Large Productive"
                size_hint_x: 1          
                size_hint_y: None
                height: dp(100) 
                length: 1
                text_size: self.width - dp(20), None
                disabled: True
                icon: "location--filled"
                on_press:
                    root.on_address_button_press(self.text.strip())

        CModalFooter:
            CGridLayout:
                cols: 2
                adaptive: [False, True]
                spacing: dp(1)

                CButtonSecondary:
                    text: "Cancel"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.dismiss()
                        root.manager.transition = FadeTransition()
                        app.root.current = 'Settings'

                CButtonPrimary:
                    text: "Add"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.countinue_pressed()

    CModalCloseButton:
        on_press:
            root.dismiss()
            root.manager.transition = FadeTransition()
            app.root.current = 'Settings'
# ---------------------------------------------------------------------------------
<ChangeLocationModal>:
    auto_dismiss: False

    CModalLayout:
        CModalHeader:
            CModalHeaderLabel:
                text: "Change Location"
            CModalHeaderTitle:
                text: "Would You Like To Change Your Location?"
        CModalBody:
            CModalBodyContent:
                text: "Changing your location will update your weather information to reflect the new city."
            CBoxLayout:
                adaptive: [False, True]
                padding: [0, dp(64)]

                CTextInputLayout:
                    size_hint_x: 0.65
                    CTextInput:
                        hint_text: "e.g. New York"
                        id: address_input
                        bg_color: [1, 1, 1, 1]
                        on_text: 
                            root.start_lookup()
                    CTextInputLabel:
                        text: "City Name"

                    CLoadingIndicator:
                        id: loader
                        role: "Small"
                        opacity: 0

            CButtonPrimary:
                text: "Start typing"
                id: address_button
                role: "Large Productive"
                size_hint_x: 1          
                size_hint_y: None
                height: dp(100) 
                length: 1
                text_size: self.width - dp(20), None
                disabled: True
                icon: "location--filled"
                on_press:
                    root.on_address_button_press(self.text.strip())

        CModalFooter:
            CGridLayout:
                cols: 2
                adaptive: [False, True]
                spacing: dp(1)

                CButtonSecondary:
                    text: "Cancel"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.dismiss()

                CButtonPrimary:
                    text: "Change"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.countinue_pressed()

    CModalCloseButton:
        on_press:
            root.dismiss()
# ---------------------------------------------------------------------------------
<DeleteLocationModal>:
    CModalLayout:
        CModalHeader:
            CModalHeaderLabel:
                text: "Delete Location"

            CModalHeaderTitle:
                text: "Are you sure you want to delete this location?"

        CModalBody:
            CModalBodyContent:
                text: "Deleting this location will permanently remove it from your account. This action cannot be undone."

        CModalFooter:
            CGridLayout:
                cols: 2
                adaptive: [False, True]
                spacing: dp(1)

                CButtonSecondary:
                    text: "Cancel"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.dismiss()

                CButtonDanger:
                    text: "Delete"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.delete_confirmed()

    CModalCloseButton:
        on_press:
            root.dismiss()