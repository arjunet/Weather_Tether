# Imports for Kv file?? (crazy, I know. But it works, and it's only 2 extra imports, so who cares?)
#:import FadeTransition kivy.uix.screenmanager.FadeTransition
#:import Window kivy.core.window.Window
# ---------------------------------------------------------------------------------
<SignupScreen>:
    CRelativeLayout:
        size_hint: 1, 1
        bg_source: "images/sun_bg.jpg"

        # Signup Label:
        CLabel:
            text: "Signup For Weather Tether"
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.9}
            font_size: min(Window.width * 0.075, sp(32))

        # Email Text Input:
        CTextInputLayout:
            pos_hint: {"center_x": 0.5, "center_y": 0.75}
            size_hint_x: None
            width: min(Window.width * 0.83, dp(400))

            CTextInput:
                hint_text: "Email"
                id: email_input
                input_type: "mail"
                bg_color: [1, 1, 1, 1]
                background_color: [1, 1, 1, 1]

            CTextInputHelperText:
                text: "Enter An Email That You Would Like to Use"
                color: "#000000"

        # Password Text Input:
        CTextInputLayout:
            pos_hint: {"center_x": 0.5, "center_y": 0.55}
            size_hint_x: None
            width: min(Window.width * 0.83, dp(400))

            CTextInput:
                hint_text: "Password"
                password: True
                id: password_input
                bg_color: [1, 1, 1, 1]
                background_color: [1, 1, 1, 1]

            CTextInputHelperText:
                text: "Enter A Password That You Would Like to Use"
                color: "#000000"

            CTextInputTrailingIconButton:
                icon: "view--off" if password_input.password else "view"
                on_press:
                    password_input.password = (not password_input.password)

        # Privacy Policy agreement:
        CLabel:
            text: "I agree to the Privacy Policy listed in the below link:"
            pos_hint: {"center_x": 0.5, "center_y": 0.43}
            typeface: "IBM Plex Sans"
            halign: "center"
            color: (0,0,0,1)
            font_size: min(Window.width * 0.04, sp(16))
            weight_style: "Medium"
        
        CLink:
            url: "https://arjunet.github.io/Weather_Tether/privacy_policy.html"
            external: True
            pos_hint: {'center_x': 0.5, 'center_y': 0.37}
            id: Link

            CLinkText:
                text: "[b]Privacy Policy[/b]"
                font_size: sp(15)
                bg_color: "white"

            CLinkIcon:
                icon: "arrow--up-right"
                bg_color: "white"

        CCheckbox:
            line_width: dp(0.75)
            right: Link.x - dp(12)
            pos_hint: {'center_y': 0.37}
            id: checkbox
            width: min(Window.width * 0.07, dp(28))
            height: min(Window.width * 0.07, dp(28))
            on_active: root.check()

        # Login Button (users already have an account):
        CButtonCircular:
            text: "Already Have An Account? Login Here"
            role: "Large Productive"
            pos_hint: {'center_x': 0.5, 'center_y': 0.3}
            icon: "right-panel--close--filled"
            bg_color: [0, 0, 0, 1]
            radius: [self.height/2]
            size_hint: None, None
            width: min(Window.width * 0.935, dp(330))
            font_size: min(Window.width * 0.044, sp(15))
            on_press:
                root.manager.transition = FadeTransition()
                root.manager.current = 'Login'

        # Forgot Password Button:
        CButtonCircular:
            text: "Forgot Your Password?"
            role: "Large Productive"
            pos_hint: {'center_x': 0.5, 'center_y': 0.2}
            icon: "help--filled"
            bg_color: [0, 0, 0, 1]
            radius: [self.height/2]
            size_hint: None, None
            width: max(Window.width * 0.136, dp(200))
            font_size: min(Window.width * 0.043, sp(14))
            on_press:
                root.manager.transition = FadeTransition()
                root.manager.current = 'Forgot'

        # Signup Button:
        CButtonCircular:
            text: "Signup"
            role: "Large Productive"
            pos_hint: {'center_x': 0.5, 'center_y': 0.1}
            icon: "login"
            bg_color: app.button_primary
            radius: [self.height/2]
            on_press:
                root.manager.transition = FadeTransition()
                root.start_load(root.ids.email_input.text, root.ids.password_input.text)

        CLoadingIndicator:
            role: "Large"
            opacity: 0
            id: loader
# ---------------------------------------------------------------------------------
<LoginScreen>:
    CRelativeLayout:
        size_hint: 1, 1
        bg_source: "images/sun_bg.jpg"

        # Login Label:
        CLabel:
            text: "Login To Weather Tether"
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.9}
            font_size: min(Window.width * 0.075, sp(32))

        # Email Text Input:
        CTextInputLayout:
            pos_hint: {"center_x": 0.5, "center_y": 0.75}
            size_hint_x: None
            width: min(Window.width * 0.83, dp(400))

            CTextInput:
                hint_text: "Email"
                id: email_input
                input_type: "mail"
                bg_color: [1, 1, 1, 1]
                background_color: [1, 1, 1, 1]

            CTextInputHelperText:
                text: "Enter Your Email"
                color: "#000000"

        # Password Text Input:
        CTextInputLayout:
            pos_hint: {"center_x": 0.5, "center_y": 0.55}
            size_hint_x: None
            width: min(Window.width * 0.83, dp(400))

            CTextInput:
                hint_text: "Password"
                password: True
                id: password_input
                bg_color: [1, 1, 1, 1]
                background_color: [1, 1, 1, 1]

            CTextInputHelperText:
                text: "Enter Your Password"
                color: "#000000"

            CTextInputTrailingIconButton:
                icon: "view--off" if password_input.password else "view"
                on_press:
                    password_input.password = (not password_input.password)

        # Privacy Policy agreement:
        CLabel:
            text: "I agree to the Privacy Policy listed in the below link:"
            pos_hint: {"center_x": 0.5, "center_y": 0.43}
            typeface: "IBM Plex Sans"
            halign: "center"
            color: (0,0,0,1)
            font_size: min(Window.width * 0.04, sp(16))
            weight_style: "Medium"
        
        CLink:
            url: "https://arjunet.github.io/Weather_Tether/privacy_policy.html"
            external: True
            pos_hint: {'center_x': 0.5, 'center_y': 0.37}
            id: Link

            CLinkText:
                text: "[b]Privacy Policy[/b]"
                font_size: sp(15)
                bg_color: "white"

            CLinkIcon:
                icon: "arrow--up-right"
                bg_color: "white"

        CCheckbox:
            line_width: dp(0.75)
            right: Link.x - dp(12)
            pos_hint: {'center_y': 0.37}
            id: checkbox
            width: min(Window.width * 0.07, dp(28))
            height: min(Window.width * 0.07, dp(28))
            on_active: root.check()

        # Back To Signup Button:
        CButtonCircular:
            text: "Back To Signup"
            role: "Large Productive"
            pos_hint: {'center_x': 0.5, 'center_y': 0.3}
            icon: "right-panel--open--filled"
            bg_color: [0, 0, 0, 1]
            radius: [self.height/2]
            size_hint: None, None
            width: max(Window.width * 0.136, dp(200))
            font_size: min(Window.width * 0.043, sp(14))
            on_press: 
                root.manager.transition = FadeTransition()
                root.manager.current = 'Signup'

        # Forgot Password Button:
        CButtonCircular:
            text: "Forgot Your Password?"
            role: "Large Productive"
            pos_hint: {'center_x': 0.5, 'center_y': 0.2}
            icon: "help--filled"
            bg_color: [0, 0, 0, 1]
            radius: [self.height/2]
            size_hint: None, None
            width: max(Window.width * 0.136, dp(200))
            font_size: min(Window.width * 0.043, sp(14))
            on_press:
                root.manager.transition = FadeTransition()
                root.manager.current = 'Forgot'

        # Login Button:
        CButtonCircular:
            text: "Login"
            role: "Large Productive"
            pos_hint: {'center_x': 0.5, 'center_y': 0.1}
            bg_color: app.button_primary
            radius: [self.height/2]
            icon: "login"
            on_press:
                root.manager.transition = FadeTransition()
                root.start_load(root.ids.email_input.text, root.ids.password_input.text)

        CLoadingIndicator:
            role: "Large"
            opacity: 0
            id: loader
# ---------------------------------------------------------------------------------
<ForgotScreen>:
    CRelativeLayout:
        size_hint: 1, 1
        bg_source: "images/sun_bg.jpg"

        # Forgot Password Label:
        CLabel:
            text: "Forgot Your Password?"
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.9}
            font_size: min(Window.width * 0.075, sp(32))

        # Email Text Input:
        CTextInputLayout:
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            size_hint_x: None
            width: min(Window.width * 0.83, dp(400))

            CTextInput:
                hint_text: "Email"
                id: email_input
                input_type: 'mail'
                bg_color: [1, 1, 1, 1]
                background_color: [1, 1, 1, 1]

            CTextInputHelperText:
                text: "Enter Your Email And We'll Send You A Code"
                color: "#000000"
                
        # Back To Signup Label:
        CButtonCircular:
            text: "Back To Signup"
            role: "Large Productive"
            pos_hint: {'center_x': 0.5, 'center_y': 0.3}
            icon: "right-panel--open--filled"
            bg_color: [0, 0, 0, 1]
            radius: [self.height/2]
            size_hint: None, None
            width: max(Window.width * 0.136, dp(200))
            font_size: min(Window.width * 0.043, sp(14))
            on_press: 
                root.manager.transition = FadeTransition()
                root.manager.current = 'Signup'

        # Back To Login Button:
        CButtonCircular:
            text: "Back To Login"
            role: "Large Productive"
            pos_hint: {'center_x': 0.5, 'center_y': 0.2}
            icon: "right-panel--open--filled"
            bg_color: [0, 0, 0, 1]
            radius: [self.height/2]
            size_hint: None, None
            width: max(Window.width * 0.136, dp(200))
            font_size: min(Window.width * 0.043, sp(14))
            on_press: 
                root.manager.transition = FadeTransition()
                root.manager.current = 'Login'

        # Send Email Button:
        CButtonCircular:
            text: "Send Email"
            role: "Large Productive"
            pos_hint: {'center_x': 0.5, 'center_y': 0.1}
            icon: "send--alt"
            bg_color: app.button_primary
            radius: [self.height/2]
            on_press:
                root.start_load(root.ids.email_input.text.strip())
                root.manager.transition = FadeTransition()
                root.manager.current = 'Login'

        CLoadingIndicator:
            role: "Large"
            opacity: 0
            id: loader
# ---------------------------------------------------------------------------------
<SetupScreen>:
    CRelativeLayout:
        size_hint: 1, 1
        bg_source: "images/sun_bg.jpg"

        # Setup Label:
        CLabel:
            text: "Setup"
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.9}
            id: setup_label
            font_size: min(Window.width * 0.075, sp(32))

        # Address Text Input:
        CTextInputLayout:
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            size_hint_x: None
            width: min(Window.width * 0.83, dp(400))

            CTextInput:
                hint_text: "City or Zip Code"
                id: address_input
                input_type: "address"
                bg_color: [1, 1, 1, 1]
                background_color: [1, 1, 1, 1]
                on_text:
                    root.start_lookup()

            CTextInputHelperText:
                text: "Enter Your City or Zip Code"
                color: "#000000"

        # Search Result Button:
        CButtonCircular:
            text: "Start typing"
            id: address_button
            role: "Large Productive"
            size_hint_x: 0.8          
            size_hint_y: None
            height: dp(180)
            pos_hint: {'y': 0}  
            text_size: self.width - dp(20), None
            disabled: True
            icon: "location--filled"
            bg_color: app.button_primary
            radius: [self.height/2]
            pos_hint: {'center_x': 0.5}
            on_press:
                root.on_address_button_press(self.text.strip())

        AnchorLayout:
            anchor_x: "right"
            anchor_y: "top"
            padding: [dp(15), dp(15), dp(15), dp(15)]
            
            # Continue Button:
            CButtonCircular:
                icon: "arrow--right"
                text: "Finish"
                radius: [self.height/2]
                bg_color: [0, 0, 0, 1]
                on_press:
                    root.manager.transition = FadeTransition()
                    root.countinue_pressed()

        CLoadingIndicator:
            role: "Large"
            opacity: 0
            id: loader
# ---------------------------------------------------------------------------------
<VerifyScreen>:
    CRelativeLayout:
        size_hint: 1, 1
        bg_source: "images/sun_bg.jpg"

        CLabel:
            text: "Please Verify Your Email Address Before Continuing"
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.9}
            font_size: min(Window.width * 0.075, sp(32))

        CLabel:
            text: "The Email Should Be In Your Inbox. If You Can't Find It, Check Your Spam"
            style: "body_01"
            typeface: "IBM Plex Sans"
            weight_style: "Regular"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5, 'center_y': 0.7}
            font_size: min(Window.width * 0.04, sp(16))

        CButtonCircular:
            text: "Resend Verification Email"
            id: resend_button
            opacity: 0
            role: "Large Productive"
            icon: "send--alt"
            pos_hint: {'center_x': 0.5, 'center_y': 0.3}
            radius: [self.height/2]
            bg_color: [0, 0, 0, 1]
            size_hint: None, None
            width: max(Window.width * 0.11, dp(270))
            font_size: min(Window.width * 0.05, sp(17))
            on_press:
                root.start_load_send()

        CButtonCircular:
            text: "Continue To App"
            role: "Large Productive"
            icon: "side-panel--open--filled"
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            radius: [self.height/2]
            bg_color: app.button_primary
            size_hint: None, None
            width: max(Window.width * 0.11, dp(220))
            font_size: min(Window.width * 0.05, sp(17))
            on_press:
                root.start_load_check()

        CLoadingIndicator:
            role: "Large"
            opacity: 0
            id: loader
# ---------------------------------------------------------------------------------
<AppScreen>:
    CRelativeLayout:
        size_hint: 1, 1
        bg_source: root.bg_image

        AsyncImage:
            id: weather_icon
            source: root.icon_path 
            size_hint: (None, None)
            size: ("200dp", "200dp")
            pos_hint: {'center_x': 0.25, 'center_y': 0.75}

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'top'
            padding: [dp(20), dp(20), dp(20), dp(20)] 

            CLabel:
                id: city_label
                style: "heading_02"
                typeface: "IBM Plex Sans"
                weight_style: "Medium"
                halign: "center"
                color: (0,0,0,1)
                pos_hint: {'center_x': 0.5, 'top': 0.97}
                font_size: sp(20)

        CLabel:
            id: current_temp_label
            style: "heading_02"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            center_x: weather_icon.center_x + dp(100)
            center_y: weather_icon.center_y + dp(15)
            font_size: min(Window.width * 0.06, sp(27))

        CLabel:
            id: condition_label
            style: "heading_04" 
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            center_x: weather_icon.center_x + dp(5)
            center_y: weather_icon.center_y - dp(60)
            font_size: min(Window.width * 0.03, sp(12))

        CLabel:
            id: min_max_label
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            center_x: weather_icon.center_x + dp(5)
            center_y: weather_icon.center_y - dp(90)
            font_size: min(Window.width * 0.03, sp(12))

        CLabel:
            id: wind_chill_label
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            center_x: weather_icon.center_x + dp(5)
            center_y: weather_icon.center_y - dp(120)
            font_size: min(Window.width * 0.03, sp(12))

        CLabel:
            id: precip_label
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5}
            center_y: weather_icon.center_y - dp(250)
            font_size: min(Window.width * 0.05, sp(19))

        CLabel:
            id: snow_label
            style: "heading_04"
            typeface: "IBM Plex Sans"
            weight_style: "Medium"
            halign: "center"
            color: (0,0,0,1)
            pos_hint: {'center_x': 0.5}
            center_y: weather_icon.center_y - dp(300)
            font_size: min(Window.width * 0.05, sp(19))

        CLoadingIndicator:
            role: "Large"
            opacity: 0
            id: loader

    UIShell:
        id: left_panel_shell

        SidePanel:
            id: SidePanel
            panel_shell: left_panel_shell
            visibility: shell_menu_btn.active

    UIShell:
        id: header_shell

        UIShellHeader:
            id: shell_header
            -bg_color: app.transparent

            UIShellHeaderMenuButton:
                id: shell_menu_btn
                on_press: root.add_buttons()

            CAnchorLayout:
                anchor_x: "right"

                CGridLayout:
                    adaptive: [True, True]
                    rows: 1
                    spacing: dp(10)
                    id: container
# ---------------------------------------------------------------------------------
